---
interface Props {
  title: string;
  slug: string;
  coverUrl: string | null;
  coverThumbUrl?: string | null;
  coverWidth?: number | null;
  coverHeight?: number | null;
  modelName: string;
  copies: number;
  type?: string;
}

const { title, slug, coverUrl, coverThumbUrl, coverWidth, coverHeight, modelName, copies, type = 'image' } = Astro.props;

function formatCount(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'k';
  return String(n);
}

const coverUrlIsVideo = /\.(mp4|webm|mov)$/i.test(coverUrl ?? '');
const isVideo = type === 'video' || coverUrlIsVideo;
const fallbackSrc = `https://picsum.photos/seed/${slug}/400/${coverHeight ?? (isVideo ? 534 : 500)}`;
const mediaSrc = coverUrl ?? fallbackSrc;
const imageSrc = coverUrlIsVideo ? coverThumbUrl : mediaSrc;
const canRenderVideo = coverUrlIsVideo && coverUrl;
const w = coverWidth ?? 400;
const h = coverHeight ?? (isVideo ? 534 : 500);
---

<article
  class="prompt-card group block break-inside-avoid mb-1.5 rounded-sm overflow-hidden relative cursor-pointer bg-bg-card"
>
  <div style={`aspect-ratio:${w}/${h}`} class="w-full overflow-hidden bg-bg-hover">
    {imageSrc ? (
      <img
        src={imageSrc}
        onerror={`this.onerror=null;this.src='${fallbackSrc}';`}
        alt={title}
        width={w}
        height={h}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover"
      />
    ) : canRenderVideo ? (
      <video
        data-lazy-video={`${mediaSrc}#t=0.5`}
        muted
        playsinline
        preload="none"
        class="w-full h-full object-cover"
      />
    ) : (
      <img
        src={fallbackSrc}
        alt={title}
        width={w}
        height={h}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover"
      />
    )}
  </div>

  <a
    href={`/prompt/${slug}`}
    class="absolute inset-0 z-10"
    aria-label={title}
  ></a>

  <div class="pointer-events-none absolute inset-0 z-20 bg-gradient-to-t from-black/70 via-black/15 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex flex-col justify-end p-3.5">
    <h3 class="text-[.875rem] font-semibold leading-[1.35] mb-1 line-clamp-2 text-white">{title}</h3>
    <div class="text-[.75rem] text-white/60 flex items-center gap-2">
      <span>{modelName}</span>
      <span>♡ {formatCount(copies)}</span>
    </div>
  </div>

  <button
    class="pointer-events-auto absolute top-2 right-2 z-30 w-[30px] h-[30px] rounded-sm bg-black/40 backdrop-blur-[8px] flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-150 hover:bg-accent border border-white/[.08]"
    data-copy-card={slug}
    title="Copy prompt"
    type="button"
  >
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
      <rect x="9" y="9" width="13" height="13" rx="2"/>
      <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
    </svg>
  </button>

  {isVideo && (
    <span class="pointer-events-none absolute top-2 left-2 z-20 flex items-center gap-1 text-[.6875rem] font-semibold px-2 py-[3px] rounded-sm bg-black/50 backdrop-blur-[8px] text-white/80">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      Video
    </span>
  )}
</article>

<script>
  import { showToast } from '@/lib/stores';

  async function copyText(text: string) {
    if (navigator.clipboard?.writeText && window.isSecureContext) {
      await navigator.clipboard.writeText(text);
      return;
    }

    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.setAttribute('readonly', '');
    textarea.style.position = 'fixed';
    textarea.style.top = '-1000px';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();

    try {
      const copied = document.execCommand('copy');
      if (!copied) throw new Error('Copy command failed');
    } finally {
      document.body.removeChild(textarea);
    }
  }

  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-copy-card]');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();
    const slug = btn.dataset.copyCard;
    try {
      const res = await fetch(`/api/prompts/${slug}`);
      if (!res.ok) throw new Error();
      const data = await res.json();
      await copyText(data.promptText ?? '');
      showToast('Copied!');
      fetch(`/api/prompts/${slug}/copy`, { method: 'POST', keepalive: true });
    } catch {
      showToast('Failed to copy');
    }
  }, { capture: true });
</script>
