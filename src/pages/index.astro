---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PromptCard from '@/components/PromptCard.astro';
import { getModels, getPrompts, getTags } from '@/lib/db/queries';
import { db } from '@/lib/db/index';
import { blogPosts } from '@/lib/db/schema';
import { eq, desc } from 'drizzle-orm';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');

const allModels = await getModels();
const allTags = await getTags();
const { items: trending } = await getPrompts({ sort: 'popular', limit: 8 });

const latestPosts = await db
  .select({ title: blogPosts.title, slug: blogPosts.slug, excerpt: blogPosts.excerpt, createdAt: blogPosts.createdAt })
  .from(blogPosts)
  .where(eq(blogPosts.status, 'published'))
  .orderBy(desc(blogPosts.createdAt))
  .limit(3);

const suggestedSearches = ['Seedance 2.0', 'Portrait', 'Cyberpunk', 'Anime', '3D Art'];
---

<BaseLayout
  title="GetPT — AI Prompt Gallery | Curated Prompts for Image & Video Generation"
  description="Hand-picked AI prompts with full parameters for pixel-perfect reproduction. Browse prompts for Seedance, Midjourney, FLUX, Stable Diffusion, DALL-E, Sora and more. One-click copy, no sign-up."
  canonical="https://getpt.net/"
>
  <div class="max-w-[1100px] mx-auto px-6">
    <!-- Hero -->
    <section class="text-center pt-[80px] pb-[56px]">
      <h1 class="text-[3.25rem] font-bold tracking-[-0.04em] leading-[1.1] mb-4">
        Find the <em class="not-italic text-accent">perfect prompt</em>,<br>create stunning AI art.
      </h1>
      <p class="text-[1.0625rem] text-text-3 max-w-[520px] mx-auto mb-8 leading-relaxed">
        Hand-picked prompts with full parameters for pixel-perfect reproduction across top AI image & video models. Updated daily.
      </p>
      <div class="flex flex-col items-center gap-3 mb-5">
        <form role="search" action="/search" class="flex items-center bg-bg-input border border-border rounded-[10px] px-3.5 gap-2 w-[460px] max-w-full transition-[border] duration-150 focus-within:border-text-3">
          <svg class="w-4 h-4 text-text-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <label for="hero-search" class="sr-only">Search</label>
          <input id="hero-search" name="q" type="text" placeholder="Search prompts, styles, models…" class="border-none bg-transparent py-2.5 w-full text-[.9375rem] outline-none text-text placeholder:text-text-3" />
        </form>
        <div class="flex gap-1.5 flex-wrap justify-center text-[.8125rem]">
          <span class="text-text-3">Try:</span>
          {suggestedSearches.map((term) => (
            <a href={`/search?q=${encodeURIComponent(term)}`} class="text-accent hover:text-accent-hover transition-colors underline underline-offset-2">
              {term}
            </a>
          ))}
        </div>
      </div>
      <a href="/gallery" class="inline-block bg-accent text-white px-7 py-[11px] rounded-[10px] text-[.9375rem] font-semibold tracking-[-0.01em] transition-all duration-150 hover:bg-accent-hover">
        Enter Gallery
      </a>
    </section>

    <!-- Featured Models -->
    <section class="pb-14">
      <div class="text-[.8125rem] font-semibold text-text-3 uppercase tracking-[.06em] mb-5 text-center">
        Models
      </div>
      <div class="flex gap-2.5 justify-center flex-wrap">
        {allModels.filter((m) => m.slug).map((m) => (
          <a
            href={`/model/${m.slug}`}
            class="flex items-center gap-2 px-4 py-2.5 rounded-[10px] border border-border bg-bg-card transition-all duration-200 hover:border-border-hover hover:-translate-y-0.5"
          >
            <span class="w-2 h-2 rounded-full shrink-0" style={`background:${m.color}`}></span>
            <span class="text-[.8125rem] font-semibold text-text-2">{m.name}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Browse by Style -->
    <section class="pb-14">
      <div class="text-[.8125rem] font-semibold text-text-3 uppercase tracking-[.06em] mb-5 text-center">
        Browse by Style
      </div>
      <div class="flex gap-2 justify-center flex-wrap">
        {allTags.map((tag) => (
          <a
            href={`/gallery?tags=${tag.id}`}
            class="px-4 py-2 rounded-full border border-border bg-bg-card text-[.8125rem] font-medium text-text-2 transition-all duration-150 hover:border-accent hover:text-accent"
          >
            {tag.name}
          </a>
        ))}
      </div>
    </section>

    <!-- Trending -->
    {trending.length > 0 && (
      <section class="pb-14">
        <div class="flex items-center justify-between mb-5">
          <div class="text-[.8125rem] font-semibold text-text-3 uppercase tracking-[.06em]">
            Trending Prompts
          </div>
          <a href="/gallery?sort=popular" class="text-[.8125rem] text-accent hover:text-accent-hover transition-colors">
            View all →
          </a>
        </div>
        <div class="columns-2 sm:columns-3 lg:columns-4 gap-1.5">
          {trending.map((p) => (
            <PromptCard
              title={p.title}
              slug={p.slug}
              coverUrl={p.coverUrl}
              coverHeight={p.coverHeight}
              modelName={p.modelName}
              copies={p.copies}
              type={p.modelType}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Latest Blog -->
    {latestPosts.length > 0 && (
      <section class="pb-14">
        <div class="flex items-center justify-between mb-5">
          <div class="text-[.8125rem] font-semibold text-text-3 uppercase tracking-[.06em]">
            Latest Articles
          </div>
          <a href="/blog" class="text-[.8125rem] text-accent hover:text-accent-hover transition-colors">
            View all →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {latestPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group p-5 rounded-[10px] border border-border bg-bg-card transition-all duration-150 hover:border-border-hover"
            >
              <h3 class="text-[.9375rem] font-semibold tracking-[-0.01em] group-hover:text-accent transition-colors mb-2 line-clamp-2">
                {post.title}
              </h3>
              {post.excerpt && (
                <p class="text-[.8125rem] text-text-3 leading-relaxed line-clamp-2 mb-3">{post.excerpt}</p>
              )}
              <time class="text-[.75rem] text-text-3" datetime={post.createdAt.toISOString().slice(0, 10)}>
                {post.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Value Props -->
    <section class="pb-16">
      <div class="flex gap-4 flex-wrap justify-center">
        <div class="flex-1 min-w-[260px] max-w-[340px] p-7 rounded-[10px] border border-border bg-bg-card">
          <h3 class="text-[.9375rem] font-semibold mb-1.5 tracking-[-0.01em]">Pixel-Perfect Reproduction</h3>
          <p class="text-[.8125rem] text-text-3 leading-relaxed">Every prompt includes complete parameters so you can reproduce the exact same result, every time.</p>
        </div>
        <div class="flex-1 min-w-[260px] max-w-[340px] p-7 rounded-[10px] border border-border bg-bg-card">
          <h3 class="text-[.9375rem] font-semibold mb-1.5 tracking-[-0.01em]">Multi-Model Coverage</h3>
          <p class="text-[.8125rem] text-text-3 leading-relaxed">Seedance, Midjourney, FLUX, Stable Diffusion, DALL-E, Sora — image and video models in one gallery.</p>
        </div>
        <div class="flex-1 min-w-[260px] max-w-[340px] p-7 rounded-[10px] border border-border bg-bg-card">
          <h3 class="text-[.9375rem] font-semibold mb-1.5 tracking-[-0.01em]">One-Click Copy</h3>
          <p class="text-[.8125rem] text-text-3 leading-relaxed">Copy prompt, parameters, or structured JSON. No sign-up. Just copy, paste, and create.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
